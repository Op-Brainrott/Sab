        cfg.StealRadius = n
        saveConfig(cfg.StealRadius, cfg.AutoSteal)
    else
        RadiusBox.Text = tostring(cfg.StealRadius)
    end
end)

local function getPromptFromPod(pod)
    if not pod then return nil end
    local base = pod:FindFirstChild("Base")
    if not base then return nil end
    local spawn = base:FindFirstChild("Spawn")
    if not spawn then return nil end
    local att = spawn:FindFirstChild("PromptAttachment")
    if not att then return nil end
    for _, p in ipairs(att:GetChildren()) do
        if p:IsA("ProximityPrompt") then return p end
    end
    return nil
end

local function scanPlot(plot)
    if not plot or not plot:IsA("Model") then return end
    if isMyBase(plot.Name) then
        myBasePlotNames[plot.Name] = true
        return
    end
    local podiums = plot:FindFirstChild("AnimalPodiums")
    if not podiums then return end
    for _, pod in ipairs(podiums:GetChildren()) do
        if pod:IsA("Model") and pod:FindFirstChild("Base") then
            local name = "Unknown"
            local spawn = pod.Base:FindFirstChild("Spawn")
            if spawn then
                for _, child in ipairs(spawn:GetChildren()) do
                    if child:IsA("Model") and child.Name ~= "PromptAttachment" then
                        name = child.Name
                        local info = AnimalsData[name]
                        if info and info.DisplayName then name = info.DisplayName end
                        break
                    end
                end
            end
            table.insert(animalCache, {
                name          = name,
                plot          = plot.Name,
                slot          = pod.Name,
                worldPosition = pod:GetPivot().Position,
                prompt        = getPromptFromPod(pod),
            })
        end
    end
end

local function execSteal(prompt)
    if not prompt or not prompt.Parent then return end
    local prev = prompt.HoldDuration
    prompt.HoldDuration = 0
    pcall(fireproximityprompt, prompt)
    prompt.HoldDuration = prev
end

local cachedTarget = nil
local lastTargetRefresh = 0

local function nearestAnimal()
    local hrp = getHRP()
    if not hrp then return nil end
    local best, bestD = nil, math.huge
    for _, ad in ipairs(animalCache) do
        if not myBasePlotNames[ad.plot] and ad.worldPosition then
            local d = (hrp.Position - ad.worldPosition).Magnitude
            if d < bestD then bestD = d; best = ad end
        end
    end
    return best
end

local function getPodFromTarget(target)
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    local plot = plots:FindFirstChild(target.plot)
    if not plot then return nil end
    local pods = plot:FindFirstChild("AnimalPodiums")
    if not pods then return nil end
    return pods:FindFirstChild(target.slot)
end

local function startStealLoop()
    if stealConn then stealConn = false end
    stealConn = true
    task.spawn(function()
        while stealConn do
            task.wait(0.05)

            if not stealActive then
                SetBarState(false)
            else
                local now = tick()

                if not cachedTarget or (now - lastTargetRefresh) >= 0.5 then
                    cachedTarget = nearestAnimal()
                    lastTargetRefresh = now
                end

                local target = cachedTarget
                if not target then
                    SetBarState(false)
                else
                    local hrp = getHRP()
                    if not hrp then
                        SetBarState(false)
                    else
                        local dist = (hrp.Position - target.worldPosition).Magnitude
                        local inRadius = dist <= cfg.StealRadius
                        SetBarState(inRadius)

                        if inRadius then
                            local prompt = target.prompt
                            if not prompt or not prompt.Parent then
                                prompt = getPromptFromPod(getPodFromTarget(target))
                                if prompt then
                                    target.prompt = prompt
                                else
                                    cachedTarget = nil
                                end
                            end
                            if prompt then execSteal(prompt) end
                        end
                    end
                end
            end
        end
    end)
end

local function scanAllPlots()
    animalCache = {}
    myBasePlotNames = {}
    cachedTarget = nil
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return end
    for _, plot in ipairs(plots:GetChildren()) do
        if plot:IsA("Model") then scanPlot(plot) end
        task.wait()
    end
end

task.spawn(function()
    task.wait(2)
    local plots = Workspace:WaitForChild("Plots", 10)
    if not plots then return end
    scanAllPlots()
    plots.ChildAdded:Connect(function(plot)
        if plot:IsA("Model") then task.wait(0.5); scanPlot(plot) end
    end)
    task.spawn(function()
        while task.wait(5) do scanAllPlots() end
    end)
    startStealLoop()
end)

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.K then
        cfg.AutoSteal = not cfg.AutoSteal
        stealActive = cfg.AutoSteal
        saveConfig(cfg.StealRadius, cfg.AutoSteal)
        if not stealActive then SetBarState(false) end
    end
end)
