local Player = Players.LocalPlayer

local CONFIG_FILE = "AutoSteal/Config.txt"

local function saveConfig(radius, autoSteal)
    local success = pcall(function()
        if not isfolder then return false end
        if not isfolder("AutoSteal") then makefolder("AutoSteal") end
        writefile(CONFIG_FILE, radius .. "," .. tostring(autoSteal))
        return true
    end)
    if not success then
        Player:SetAttribute("AS_Radius", radius)
        Player:SetAttribute("AS_Auto", autoSteal)
    end
end

local function loadConfig()
    local radius = 12
    local autoSteal = true
    local success = pcall(function()
        if isfolder and isfolder("AutoSteal") and isfile(CONFIG_FILE) then
            local data = readfile(CONFIG_FILE)
            local r, a = data:match("([^,]+),([^,]+)")
            if r then radius = tonumber(r) or 12 end
            if a then autoSteal = (a == "true") end
            return true
        end
        return false
    end)
    if not success then
        local r = Player:GetAttribute("AS_Radius")
        local a = Player:GetAttribute("AS_Auto")
        if r then radius = r end
        if a ~= nil then autoSteal = a end
    end
    return radius, autoSteal
end

local savedRadius, savedAutoSteal = loadConfig()

