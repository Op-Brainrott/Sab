local lastInRadius = false
local function SetBarState(inRadius)
    if inRadius == lastInRadius then return end
    lastInRadius = inRadius
    if inRadius then
        tw(BarFill, { Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = T.PrgGreen }, 0.15)
    else
        tw(BarFill, { Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = T.PrgFill }, 0.15)
    end
end

